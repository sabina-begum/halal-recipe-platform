{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview -- --host 127.0.0.1 --port 4173",
      "startServerReadyPattern": "Local:",
      "puppeteerScript": "scripts/lighthouse-auth-session.cjs",
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage --disable-gpu"
      },
      "url": [
        "http://127.0.0.1:4173/profile",
        "http://127.0.0.1:4173/favorites",
        "http://127.0.0.1:4173/collections",
        "http://127.0.0.1:4173/meal-planning",
        "http://127.0.0.1:4173/shopping-list",
        "http://127.0.0.1:4173/nutrition-tracker"
      ]
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
