{
  "name": "culinaria",
  "private": true,
  "version": "1.0.0",
  "description": "CULINARIA - Professional Cooking Platform & Recipe Discovery",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "protect": "node scripts/protect-code.js",
    "security-check": "node scripts/security-monitor.js",
    "copyright-check": "node scripts/protect-code.js && node scripts/security-monitor.js",
    "deploy": "node scripts/deploy.js",
    "deploy:vercel": "npm run deploy && vercel",
    "deploy:netlify": "npm run deploy && netlify deploy",
    "deploy:firebase": "npm run deploy && firebase deploy",
    "type-check": "tsc --noEmit",
    "performance": "npm run build && npm run preview",
    "cleanup": "node scripts/dev-cleanup.js",
    "cleanup:full": "node scripts/dev-cleanup.js --full",
    "cleanup:check": "node scripts/dev-cleanup.js --check",
    "dev:clean": "npm run cleanup && npm run dev",
    "dev:fresh": "npm run cleanup:full && npm install && npm run dev",
    "health-check": "node -e \"import('./src/utils/moduleHealthCheck.js').then(m => m.default.logHealthCheck())\"",
    "troubleshoot": "npm run cleanup:check && npm run health-check",
    "test": "jest",
    "test:watch": "jest --watch",
    "a11y:ci": "lhci autorun",
    "a11y:ci:auth": "lhci autorun --config=lighthouserc.auth.json"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.6",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "ts-jest": "^29.4.9",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "overrides": {
    "handlebars": "4.7.9",
    "brace-expansion": "5.0.5",
    "minimatch": "^10.0.3",
    "picomatch": "^4.0.4",
    "tar": "^7.5.11",
    "tmp": "^0.2.5"
  }
}
